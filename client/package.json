{
  "name": "client",
  "private": true,
  "version": "0.0.0-SNAPSHOT",
  "type": "module",
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "cd .. && husky client/.husky",
    "pre-commit": "lint-staged",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "../scripts/playwright-test.sh",
    "download:api": "curl -s http://localhost:8080/api/v1/public/docs -o ../server/openapi.json",
    "generate:api": "openapi-typescript ../server/openapi.json -o src/lib/types/api.d.ts"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lint-staged": "^15.5.2",
    "mode-watcher": "^1.1.0",
    "openapi-fetch": "^0.15.0",
    "svelte-sonner": "^1.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2"
  },
  "devDependencies": {
    "@internationalized/date": "^3.10.1",
    "@lucide/svelte": "^0.561.0",
    "@playwright/test": "^1.57.0",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/enhanced-img": "^0.8.5",
    "@sveltejs/kit": "^2.49.3",
    "@sveltejs/vite-plugin-svelte": "^6.2.3",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@types/d3-scale": "^4.0.9",
    "autoprefixer": "^10.4.23",
    "bits-ui": "^2.15.4",
    "husky": "^9.1.7",
    "layerchart": "^2.0.0-next.44",
    "openapi-typescript": "^7.10.1",
    "postcss": "^8.5.6",
    "shadcn-svelte": "^1.1.0",
    "svelte": "^5.46.1",
    "svelte-adapter-bun": "^1.0.1",
    "svelte-check": "^4.3.5",
    "svelte-preprocess": "^6.0.3",
    "tailwindcss": "^4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
