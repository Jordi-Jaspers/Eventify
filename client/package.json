{
  "name": "client",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "pre-commit": "lint-staged",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest",
    "download:api": "curl -s http://localhost:8080/api/v1/public/docs -o ../server/openapi.json",
    "generate:api": "openapi-typescript ../server/openapi.json -o src/lib/types/api.d.ts"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lint-staged": "^15.4.3",
    "mode-watcher": "^1.1.0",
    "openapi-fetch": "^0.15.0",
    "svelte-sonner": "^1.0.6",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.1.1"
  },
  "devDependencies": {
    "@internationalized/date": "^3.8.1",
    "@lucide/svelte": "^0.553.0",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/enhanced-img": "^0.8.4",
    "@sveltejs/kit": "^2.47.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/postcss": "^4.1.17",
    "@tailwindcss/typography": "^0.5.19",
    "@types/d3-scale": "^4.0.9",
    "@vitest/ui": "^4.0.8",
    "autoprefixer": "^10.4.22",
    "bits-ui": "^2.14.4",
    "layerchart": "^2.0.0-next.43",
    "openapi-typescript": "^7.10.1",
    "postcss": "^8.5.6",
    "shadcn-svelte": "^1.0.11",
    "svelte": "^5.41.0",
    "svelte-adapter-bun": "^1.0.1",
    "svelte-check": "^4.3.3",
    "svelte-preprocess": "^6.0.3",
    "tailwindcss": "^4.1.17",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.10",
    "vitest": "^4.0.8"
  }
}
