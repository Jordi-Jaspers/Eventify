{
  "name": "client",
  "private": true,
  "version": "1.1.0-SNAPSHOT",
  "type": "module",
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "cd .. && husky client/.husky",
    "pre-commit": "lint-staged",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "sync:api": "../scripts/openapi-sync.sh",
    "download:api": "curl -s http://localhost:8080/api/v1/public/docs -o ../server/openapi.json",
    "generate:api": "openapi-typescript ../server/openapi.json -o src/lib/types/api.d.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lint-staged": "^16.4.0",
    "mode-watcher": "^1.1.0",
    "openapi-fetch": "^0.17.0",
    "svelte-sonner": "^1.1.1",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2"
  },
  "devDependencies": {
    "@internationalized/date": "^3.12.1",
    "@lucide/svelte": "^1.14.0",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/enhanced-img": "^0.10.4",
    "@sveltejs/kit": "^2.59.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "@types/d3-scale": "^4.0.9",
    "@types/node": "^25.6.2",
    "@vitest/ui": "^4.1.5",
    "bits-ui": "^2.18.1",
    "husky": "^9.1.7",
    "layerchart": "^2.0.0-next.62",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.14",
    "shadcn-svelte": "^1.2.7",
    "svelte": "^5.55.5",
    "svelte-adapter-bun": "^1.0.1",
    "svelte-check": "^4.4.8",
    "svelte-preprocess": "^6.0.3",
    "tailwindcss": "^4.2.4",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}
