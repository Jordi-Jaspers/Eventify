# Backend API Base URL
VITE_SERVER_BASE_URL=http://localhost:8080

# Environment identifier - controls branding and dev features
# Values:
#   'local' - Red DEV badge on favicon/logo, shows dev credentials on login
#   'test'  - Green TST badge on favicon/logo, shows dev credentials on login
#   'production' - No badge, no dev features (default if not set)
#
# This is a runtime variable - can be changed without rebuilding
PUBLIC_ENVIRONMENT=local
